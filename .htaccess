Options -MultiViews
RewriteEngine On

# Handle Catalyst Codex app routing (for /catalyst-codex/* paths)
RewriteCond %{REQUEST_URI} ^/catalyst-codex/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^catalyst-codex/(.*)$ catalyst-codex/index.html [L]

# Handle main site routing (for all other paths)
# If request is NOT for catalyst-codex and file doesn't exist, serve main index.html
RewriteCond %{REQUEST_URI} !^/catalyst-codex/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . index.html [L]

# Optional: Set proper MIME types and caching
<FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000"
</FilesMatch>

# Ensure proper handling of static assets
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule . - [L]